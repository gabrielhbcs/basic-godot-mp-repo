; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="basic-mp"
run/main_scene="res://scenes/login_menu.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[audio]

driver/enable_input=true
driver/mix_rate=48000

[autoload]

EventBus="*res://autoloads/event_bus.gd"
PlayerManager="*res://autoloads/player_manager.gd"
NetworkManager="*res://autoloads/network_manager.gd"
VoipNetwork="*res://autoloads/voip_network.gd"
SettingsManager="*res://autoloads/settings_manager.gd"
Localization="*res://autoloads/localization.gd"

